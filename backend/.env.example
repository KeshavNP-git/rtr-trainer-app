# RTR TRAINER — Backend Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real keys
# 3. NEVER commit .env to GitHub

# Gemini AI API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs Text-to-Speech — https://elevenlabs.io/ → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID (Adam = pNInz6obpgDQGcFmaJgB — deep male ATC voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Port (Render sets this automatically — keep 3001 for local dev)
PORT=3001

# Your Vercel frontend URL (update after Vercel deploy)
FRONTEND_URL=http://localhost:5173
